datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  ADMIN
  MANAGER
  USER
  AUDITOR
}

enum DocumentType {
  PDF
  DOCX
  ZIP
  PROPOSAL
  INVOICE
  SPREADSHEET
  QUOTATION
  RECEIPT
  PURCHASE_ORDER
  PROFORMA_INVOICE
  CREDIT_NOTE
  DEBIT_NOTE
  AGREEMENT
}

enum DocumentStatus {
  DRAFT
  REVIEW
  COMPLETED
  ARCHIVED
  SENT
  APPROVED
  REJECTED
  PAID
  CANCELLED
}

enum ActivityType {
  EDIT
  COMMENT
  APPROVE
  REJECT
  SYSTEM
}

enum RenewalType {
  SOFTWARE
  LEASE
  INSURANCE
  CONTRACT
  DOMAIN
  HOSTING
  SSL
  AMC
  MAINTENANCE
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  firstName    String
  lastName     String
  role         UserRole   @default(USER)
  mfaEnabled   Boolean    @default(false)
  mfaSecret    String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  documents    Document[] @relation("DocumentAuthor")
  activities   Activity[]
  comments     Comment[]

  @@map("users")
}

model Company {
  id                 String           @id @default(uuid())
  name               String
  registrationNumber String?
  taxId              String?
  addressLine1       String
  addressLine2       String?
  city               String
  postalCode         String
  country            String
  bankName           String?
  bankIban           String?
  bankBic            String?
  customFields       Json?            // Dynamic custom fields store (JSON object)
  gstRegistrations   Json?            // Multi-GST registries store (JSON array)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  documents          Document[]
  customers          Customer[]
  addresses          Address[]
  contacts           Contact[]
  bankAccounts       BankAccount[]
  attachments        Attachment[]
  notes              Note[]
  branding           CompanyBranding?

  @@map("companies")
}

model Customer {
  id               String        @id @default(uuid())
  companyId        String
  company          Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name             String
  email            String
  phone            String?
  addressLine1     String?
  addressLine2     String?
  city             String?
  postalCode       String?
  country          String?
  status           String        @default("ACTIVE") // ACTIVE, INACTIVE
  customFields     Json?         // Dynamic custom fields store (JSON object)
  gstRegistrations Json?         // Multi-GST registries store (JSON array)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  documents        Document[]
  addresses        Address[]
  contacts         Contact[]
  bankAccounts     BankAccount[]
  attachments      Attachment[]
  notes            Note[]

  @@map("customers")
}

model Address {
  id         String    @id @default(uuid())
  companyId  String?
  company    Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type       String    // "BILLING", "SHIPPING"
  line1      String
  line2      String?
  city       String
  postalCode String
  country    String
  isDefault  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("addresses")
}

model Contact {
  id         String    @id @default(uuid())
  companyId  String?
  company    Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  firstName  String
  lastName   String
  email      String
  phone      String?
  role       String?   // "PRIMARY", "BILLING", "DECISION_MAKER", etc.
  isDefault  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("contacts")
}

model BankAccount {
  id            String    @id @default(uuid())
  companyId     String?
  company       Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  bankName      String
  accountHolder String
  accountNumber String
  iban          String?
  bic           String?
  isDefault     Boolean   @default(false)
  gstNumber     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("bank_accounts")
}

model Product {
  id          String            @id @default(uuid())
  sku         String            @unique
  name        String
  description String?           @db.Text
  rate        Decimal           @db.Decimal(10, 2)
  unitId      String?
  unit        Unit?             @relation(fields: [unitId], references: [id], onDelete: SetNull)
  taxId       String?
  tax         TaxConfiguration? @relation(fields: [taxId], references: [id], onDelete: SetNull)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("products")
}

model Unit {
  id        String    @id @default(uuid())
  code      String    @unique // e.g., "HR", "DAY", "ITEM"
  name      String
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("units")
}

model TaxConfiguration {
  id          String    @id @default(uuid())
  name        String
  ratePercent Decimal   @db.Decimal(5, 2)
  code        String    @unique // e.g., "GST-18", "VAT-20", "EXEMPT"
  isDefault   Boolean   @default(false)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("tax_configurations")
}

model PaymentTerm {
  id          String   @id @default(uuid())
  name        String   @unique // e.g., "Net 30", "Due on Receipt"
  daysDue     Int
  description String?  @db.VarChar(1000)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("payment_terms")
}

model Currency {
  id           String   @id @default(uuid())
  code         String   @unique // e.g., "USD", "EUR", "INR"
  name         String
  symbol       String
  exchangeRate Decimal  @db.Decimal(12, 6) @default(1.0)
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("currencies")
}

model DocumentNumbering {
  id            String   @id @default(uuid())
  documentType  String   @unique // e.g., "INVOICE", "PROPOSAL"
  prefix        String
  suffix        String?
  currentNumber Int      @default(1)
  paddingDigits Int      @default(4)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("document_numberings")
}

model Tag {
  id         String   @id @default(uuid())
  name       String
  color      String   // Hex code
  entityType String   // e.g., "COMPANY", "CUSTOMER", "DOCUMENT"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([name, entityType])
  @@map("tags")
}

model Attachment {
  id         String    @id @default(uuid())
  filename   String
  filepath   String
  mimetype   String
  sizeBytes  Int
  uploaderId String
  documentId String?
  companyId  String?
  company    Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("attachments")
}

model Note {
  id         String    @id @default(uuid())
  content    String    @db.Text
  authorId   String
  companyId  String?
  company    Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("notes")
}

model Document {
  id               String            @id @default(uuid())
  title            String
  type             DocumentType
  customType       String?           // Dynamic Custom Document Types configured by admins
  status           DocumentStatus    @default(DRAFT)
  fileUrl          String?
  companyId        String?
  company          Company?          @relation(fields: [companyId], references: [id], onDelete: SetNull)
  customerId       String?
  customer         Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  authorId         String
  author           User              @relation("DocumentAuthor", fields: [authorId], references: [id])
  accentColor      String?
  fontFamily       String?
  showWatermark    Boolean           @default(false)
  watermarkText    String?
  showStamp        Boolean           @default(false)
  templateId       String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  blocks           DocumentBlock[]
  versions         DocumentVersion[]
  activities       Activity[]
  comments         Comment[]
  renewals         Renewal[]
  recurringConfigs RecurringConfig[]

  @@map("documents")
}

model DocumentBlock {
  id         String   @id @default(uuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  sortOrder  Int      @default(0)
  blockType  String   // e.g., "COVER", "TEXT", "TABLE", "NOTES"
  content    String   @db.Text // JSON string representing properties specific to this block
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("document_blocks")
}

model DocumentVersion {
  id         String   @id @default(uuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version    Int
  title      String
  content    String   @db.Text // Serialized JSON of all document blocks
  createdAt  DateTime @default(now())

  @@map("document_versions")
}

model Activity {
  id         String       @id @default(uuid())
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  actionType ActivityType
  documentId String?
  document   Document?    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  details    String       @db.VarChar(1000)
  createdAt  DateTime     @default(now())

  @@map("activities")
}

model Renewal {
  id               String        @id @default(uuid())
  documentId       String?
  document         Document?     @relation(fields: [documentId], references: [id], onDelete: SetNull)
  itemName         String
  renewalType      RenewalType
  renewalDate      DateTime
  amount           Decimal       @db.Decimal(10, 2)
  status           String        @default("PENDING") // PENDING, COMPLETED, CANCELLED
  vendor           String?
  purchaseDate     DateTime?
  gracePeriodDays  Int           @default(0)
  paymentStatus    String        @default("UNPAID") // UNPAID, PAID, OVERDUE
  assignedEmployee String?
  notes            String?       @db.Text
  emailId          String?
  password         String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  reminders        ReminderLog[]

  @@map("renewals")
}

model Comment {
  id         String   @id @default(uuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  text       String   @db.VarChar(1000)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("comments")
}

model ReminderLog {
  id         String   @id @default(uuid())
  renewalId  String
  renewal    Renewal  @relation(fields: [renewalId], references: [id], onDelete: Cascade)
  daysBefore Int
  sentAt     DateTime @default(now())
  status     String   @default("SENT") // SENT, FAILED
  details    String?  @db.VarChar(1000)

  @@map("reminder_logs")
}

model EmailJob {
  id           String   @id @default(uuid())
  recipient    String
  subject      String
  message      String   @db.Text
  status       String   @default("PENDING") // PENDING, SENT, FAILED
  retryCount   Int      @default(0)
  errorMessage String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("email_jobs")
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String   @db.VarChar(1000)
  type      String   @default("INFO") // INFO, WARNING, SUCCESS, ERROR
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}

model RecurringConfig {
  id          String   @id @default(uuid())
  documentId  String
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  frequency   String   // "MONTHLY", "QUARTERLY", "ANNUALLY"
  startDate   DateTime
  endDate     DateTime?
  nextRunDate DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("recurring_configs")
}

model CustomFieldConfig {
  id         String   @id @default(uuid())
  entityType String   // "COMPANY", "CUSTOMER", "DOCUMENT"
  fieldName  String
  fieldLabel String
  fieldType  String   // "TEXT", "NUMBER", "DATE", "DROPDOWN" etc.
  validation String?
  isRequired Boolean  @default(false)
  options    String?  // Comma separated options list
  createdAt  DateTime @default(now())

  @@map("custom_field_configs")
}

model CustomDocumentType {
  id          String   @id @default(uuid())
  name        String   @unique
  label       String
  prefix      String
  description String?
  createdAt   DateTime @default(now())

  @@map("custom_document_types")
}

model WorkspacePreference {
  id          String   @id @default(uuid())
  userId      String
  densityMode String   @default("DEFAULT") // COMPACT, DEFAULT, COMFORTABLE
  theme       String   @default("LIGHT")
  shortcuts   String?  @db.Text
  savedViews  String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("workspace_preferences")
}

model CompanyBranding {
  id           String   @id @default(uuid())
  companyId    String   @unique
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  logoUrl      String?
  signatures   Json?    // signature URLs list
  stamps       Json?    // stamp URLs list
  letterhead   String?  @db.Text
  primaryColor String   @default("#3525CD")
  fontFamily   String   @default("inter")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("company_brandings")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String   // e.g., "LOGIN_SUCCESS", "LOGIN_FAILED", "LOGOUT", "PASSWORD_UPDATE", "EXPORT_AUDIT_REPORT"
  ipAddress String?
  userAgent String?
  details   String?  @db.Text
  createdAt DateTime @default(now())

  @@map("audit_logs")
}
