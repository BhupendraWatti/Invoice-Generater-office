{
  "name": "docflow-workspace-studio",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev:api": "pnpm --filter @docflow/api dev",
    "dev:web": "pnpm --filter @docflow/web dev",
    "dev": "pnpm --filter @docflow/api --filter @docflow/web --parallel dev",
    "build": "pnpm -r build",
    "db:generate": "pnpm --filter @docflow/db generate",
    "db:migrate": "pnpm --filter @docflow/db migrate:dev",
    "db:seed": "pnpm --filter @docflow/db seed"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "bcrypt",
      "sharp"
    ]
  }
}
